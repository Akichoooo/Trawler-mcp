# ── Trawler-mcp 环境变量样例 ──────────────────────────────
# 复制为 .env 并按需修改。所有变量可选, 不设走默认。
# 前缀统一 TRAWLER_

# ── 路径 ──
# 数据根目录 (db / raw / account_vault 都在其下)
# TRAWLER_DATA_DIR=./data

# ── 安全 ──
# SSRF 守卫: 是否放行内网/环回地址。默认 false (拦截)。
# 仅在你明确要爬内网时设 1。
# TRAWLER_ALLOW_LOCAL=0
# Optional: allow domain DNS results in proxy/TUN fake-ip CIDRs (literal IP URLs still block).
# Keep disabled unless your DNS maps public domains to 198.18.0.0/15 or another fake-ip range.
# TRAWLER_SSRF_ALLOW_FAKE_IP_DNS=0
# TRAWLER_SSRF_FAKE_IP_CIDRS=198.18.0.0/15
# Browser route SSRF DNS cache TTL in seconds. Lower reduces DNS rebinding window.
# TRAWLER_BROWSER_ROUTE_DNS_CACHE_TTL=15.0
# Existing-browser CDP connections are localhost-only by default. Enable remote CDP only
# for an explicitly trusted endpoint/network.
# TRAWLER_ALLOW_REMOTE_CDP=0
# Browser sessions fail closed if request route SSRF guard cannot be installed.
# TRAWLER_ALLOW_UNGUARDED_BROWSER=0

# Central MCP policy broker.
# permissive keeps local-dev compatibility while reporting decisions.
# strict denies risky calls without an allowed domain/target and rejects unknown tools.
# TRAWLER_POLICY_MODE=permissive
# Optional comma/semicolon/newline separated domain patterns. Examples:
# TRAWLER_ALLOWED_DOMAINS=example.com,*.example.org
# TRAWLER_BLOCKED_DOMAINS=169.254.169.254,localhost
# Ability gates for high-security deployments.
# TRAWLER_ENABLE_LIVE_BROWSER=1
# TRAWLER_ENABLE_CDP=1
# TRAWLER_ENABLE_CRAWL_SITE=1

# HITL 自动过码 (CapSolver)。默认空 (不启用, 走人工弹窗)。
# 设为你的 CapSolver API key 则自动过 CAPTCHA, 责任自负。
# TRAWLER_CAPSOLVER_KEY=

# Cookie 加密 vault (Fernet key)。HITL 登录态持久化必须。
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 未设则跳过账号态路径 (无 HITL), 容器仍可启动做无账号爬取。
# TRAWLER_VAULT_KEY=
# Account Profile Registry stores metadata in SQLite and encrypted-state paths in account_vault.
# It never stores plaintext passwords; use visible browser login for manual auth/verification.

# robots.txt 合规 (RFC 9309)。默认 1 (尊重)。
# 2026 已有 35% top10k 站加 AI-bot Disallow。升级注意: 此前版本未实现 robots 检查,
# 升级后可能突然被某些站 blocked-robots。force_refresh=True 可绕过单次检查。
# TRAWLER_RESPECT_ROBOTS=1

# ── 代理 ──
# HTTP_PROXY=
# HTTPS_PROXY=
# Optional sticky proxy pool. Split with comma, semicolon, or whitespace.
# TRAWLER_PROXY_POOL=http://proxy-a:8080,http://proxy-b:8080

# ── 超时 (秒) ──
# crawl_url 墙钟上限 (curl_cffi 3-retry stack may need ~35s; MCP client should set >=40s)
# TRAWLER_CRAWL_TIMEOUT=35
# patchright 单次抓取
# TRAWLER_PATCHRIGHT_TIMEOUT=30
# Jina Reader
# TRAWLER_JINA_TIMEOUT=15
# html2text 解析超时
# TRAWLER_HTML2TEXT_TIMEOUT=5
# HITL 人工等待
# TRAWLER_HITL_TIMEOUT=60

# ── 爬取规模 ──
# crawl_site 默认页数 (聚合 md 进 agent context, 不宜过大)
# TRAWLER_MAX_PAGES=20
# crawl_site 硬上限
# TRAWLER_MAX_PAGES_HARD=500
# Optional crawl budget: 0 disables max error stop.
# TRAWLER_CRAWL_MAX_ERRORS=0
# TRAWLER_MAX_LINKS_PER_PAGE=200
# 全局并发上限
# TRAWLER_SEMAPHORE=3

# ── 资源回收 ──
# account_vault 保留的 profile 域数 (LRU 清理)
# TRAWLER_PROFILE_TOPN=50
# HTML 硬截断字节 (防 OOM)
# TRAWLER_HTML_TRUNCATE=2097152

# ── 去重缓存 TTL (秒) ──
# TRAWLER_CACHE_TTL_NEWS=3600
# TRAWLER_CACHE_TTL_WIKI=604800
# TRAWLER_CACHE_TTL_DEFAULT=21600

# ── 手册置信度 ──
# 低于此值标 stale, 下次跳过走默认阶梯
# TRAWLER_CONFIDENCE_MIN=0.5
# 连续失败 N 天标 unreachable, TTL 内不重试
# TRAWLER_UNREACHABLE_TTL=86400

# Debug artifacts (out-of-band diagnostics for failures)
# Modes: off, fail, sample, always
# TRAWLER_DEBUG_ARTIFACTS=fail
# TRAWLER_ARTIFACT_DIR=./data/artifacts
# TRAWLER_ARTIFACT_HTML_MAX_BYTES=524288
# TRAWLER_ARTIFACT_SAMPLE_RATE=0.05
# TRAWLER_ARTIFACT_RETENTION_DAYS=14
# TRAWLER_ARTIFACT_MAX_BYTES=536870912
# Expose page.html via MCP get_artifact; keep disabled unless caller is trusted.
# TRAWLER_EXPOSE_ARTIFACT_BODIES=0

# Sitemap/feed discovery limits
# TRAWLER_SITE_INDEX_MAX_BYTES=1048576
# TRAWLER_SITE_INDEX_CHILD_SITEMAPS=10
# TRAWLER_FRONTIER_MAX_RETRIES=2
# TRAWLER_FRONTIER_RETRY_BASE_SECONDS=2.0
